{
  "mcpServers": {
    "git-tools": {
      "command": "{{PYTHON_VENV_PATH}}/mcp-git-tools.exe"
    },
    "github-tools": {
      "command": "{{PYTHON_VENV_PATH}}/mcp-github-tools.exe",
      "env": {
        "GH_PROMPT_DISABLED": "1"
      }
    },
    "template-sync-tools": {
      "command": "{{PYTHON_VENV_PATH}}/mcp-template-sync-tools.exe"
    },
    "ollama-tools": {
      "command": "{{PYTHON_VENV_PATH}}/mcp-ollama-tools.exe",
      "env": {
        "OLLAMA_URL": "http://127.0.0.1:11434",
        "OLLAMA_MODEL_FIRST_PASS": "{{OLLAMA_MODEL_FIRST_PASS}}",
        "OLLAMA_MODEL_EXTRACT_JSON": "{{OLLAMA_MODEL_EXTRACT_JSON}}"
      }
    },
    "open-brain": {
      "command": "{{OPEN_BRAIN_COMMAND}}",
      "args": ["{{OPEN_BRAIN_ARGS}}"]
    },
    "searxng": {
      "command": "{{SEARXNG_COMMAND}}",
      "args": ["{{SEARXNG_ARGS}}"],
      "env": {
        "SEARXNG_URL": "{{SEARXNG_INSTANCE_URL}}"
      }
    }
  }
}
